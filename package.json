    "test:browser": "karma start karma.conf.cjs --singleRun=true",
    "test:node": "c8 mocha"
  },
  "config": {
    "ghooks": {
      "commit-msg": "validate-commit-msg"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.1.0",
    "ghooks": "^2.0.4",
    "globals": "^17.4.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-mocha": "^2.0.1",
    "mocha": "^11.7.5",
    "semantic-release": "^25.0.3",
    "validate-commit-msg": "^2.3.1"
  },
  "engines": {
    "node": ">= 12"
  },
  "version": "3.0.0"
